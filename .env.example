# Copy this file to .env and fill in your values
# cp .env.example .env

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database (leave blank to use SQLite fallback)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=hms_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Timezone
TIME_ZONE=Asia/Kolkata

# Email service URL (default points to local_server.py)
EMAIL_SERVICE_BASE_URL=http://localhost:3000/dev

# Email service SMTP (set in the email-service terminal, not here)
# SMTP_USER=your.gmail@gmail.com
# SMTP_PASS=your-16-char-app-password
